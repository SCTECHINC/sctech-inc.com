# ============================================================
# SC Tech Inc — sctech-inc.com
# ============================================================
#
# Copy this file to `.env.local` for local development, or set
# these variables in Vercel → Project → Settings → Environment
# Variables for production.
#
# These match the same keys used across the Rebel ecosystem
# (ht-project-managers, rebel-os-api) so credentials can be
# reused if desired.
#
# ============================================================
# Mailjet — powers the contact form at /api/contact
# ============================================================

# Required — Mailjet API key (public) and secret (private).
# Get these from https://app.mailjet.com/account/apikeys
MAILJET_API_KEY=
MAILJET_SECRET_KEY=

# Optional — "From" address on outgoing notification emails.
# Must be a verified sender in Mailjet before it will deliver.
# Defaults: noreply@sctech-inc.com / "SC Tech Website"
MAILJET_FROM_EMAIL=noreply@sctech-inc.com
MAILJET_FROM_NAME=SC Tech Website
